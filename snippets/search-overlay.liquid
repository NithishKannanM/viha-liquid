{%- comment -%} Search Overlay — rendered via layout/theme.liquid {%- endcomment -%}
<div class="search-overlay" id="search-overlay" role="dialog" aria-label="Search" aria-modal="true">
  <div class="search-overlay__header">
    <span style="font-family:var(--font-heading);font-size:1.125rem;font-weight:700;color:var(--color-maroon);">Search Viha Heritage</span>
    <button class="header__icon-btn" data-search-close aria-label="Close search">
      <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <div class="search-overlay__body">
    <div class="search-overlay__input-wrap">
      <span class="search-overlay__input-icon" aria-hidden="true">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
        </svg>
      </span>
      <input
        type="search"
        class="search-overlay__input"
        placeholder="Search for products, ingredients…"
        autocomplete="off"
        autocorrect="off"
        spellcheck="false"
        data-search-input
        aria-label="Search products"
      >
    </div>
    <div data-search-results></div>

    {%- comment -%} Popular searches {%- endcomment -%}
    <div style="margin-top:2rem;">
      <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--color-gold);margin-bottom:0.75rem;">Popular Searches</p>
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        {%- assign popular = "Kumkumadi,Sandalwood Soap,Vetiver Scrub,Jasmine Attar,Bhringraj Oil,Ashwagandha,Hair Oil,Gift Sets" | split: "," -%}
        {%- for term in popular -%}
          <button style="padding:6px 14px;border:1px solid var(--color-cream-dark);font-size:11px;color:rgba(45,45,45,0.8);border-radius:2px;transition:all 0.15s;cursor:pointer;"
            onclick="document.querySelector('[data-search-input]').value='{{ term }}';document.querySelector('[data-search-input]').dispatchEvent(new Event('input'));"
            onmouseover="this.style.borderColor='var(--color-gold)';this.style.color='var(--color-maroon)'"
            onmouseout="this.style.borderColor='var(--color-cream-dark)';this.style.color='rgba(45,45,45,0.8)'">
            {{ term }}
          </button>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

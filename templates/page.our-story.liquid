{%- comment -%} Our Heritage Story page — assign template "page.our-story" in Admin {%- endcomment -%}

{%- comment -%} ── Hero ─────────────────────────────────────────────────────── {%- endcomment -%}
<section style="background:var(--color-maroon);padding:5rem 1.5rem 4rem;text-align:center;">
  <p style="font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:1rem;">Our Heritage Story</p>
  <h1 style="font-family:var(--font-heading);font-size:clamp(2.25rem,6vw,3.5rem);font-weight:900;color:#fff;line-height:1.1;max-width:700px;margin:0 auto 1.25rem;">
    Preserving Tradition,<br>Promoting Wellness.
  </h1>
  <p style="font-size:14px;color:rgba(255,255,255,0.7);max-width:540px;margin:0 auto;line-height:1.8;">
    Rooted in five thousand years of Indian tradition. Every product we offer is personally selected to bring authentic, time-honoured essentials into your home.
  </p>
</section>

{%- comment -%} ── Gold divider ──────────────────────────────────────────────── {%- endcomment -%}
<div style="height:4px;background:linear-gradient(90deg,transparent,var(--color-gold),transparent);"></div>

{%- comment -%} ── Founder Section ───────────────────────────────────────────── {%- endcomment -%}
<section style="background:var(--color-paper);padding:5rem 1.5rem;">
  <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr;gap:3rem;align-items:center;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:center;">

      {%- comment -%} Founder portrait placeholder {%- endcomment -%}
      <div style="aspect-ratio:3/4;background:var(--color-cream-dark);border-radius:2px;overflow:hidden;position:relative;">
        {% if settings.logo != blank %}
          <img src="{{ settings.logo | img_url: '600x' }}" alt="Mrs Anitha Kuppusamy" style="width:100%;height:100%;object-fit:cover;">
        {% else %}
          <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1rem;padding:2rem;text-align:center;">
            <svg width="64" height="64" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color:rgba(45,45,45,0.2);" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
            </svg>
            <p style="font-size:11px;color:rgba(45,45,45,0.35);font-style:italic;">Upload founder photo<br>in Shopify Admin → Files</p>
          </div>
        {% endif %}
        <div style="position:absolute;bottom:0;left:0;right:0;padding:1.5rem;background:linear-gradient(to top,rgba(0,0,0,0.6),transparent);">
          <p style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:#fff;margin:0;">Mrs. Anitha Kuppusamy</p>
          <p style="font-size:10px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--color-gold);margin-top:4px;">Founder · Viha Heritage Store</p>
        </div>
      </div>

      {%- comment -%} Founder story text {%- endcomment -%}
      <div>
        <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:1rem;">The Founder</p>
        <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);line-height:1.15;margin-bottom:1.5rem;">A Devotion Turned<br>into a Mission</h2>
        <p style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.85;margin-bottom:1.25rem;">
          Viha Heritage Store was born from a deep reverence for Indian spiritual traditions and holistic wellness. Mrs Anitha Kuppusamy grew up immersed in the rituals, fragrances, and sacred craftsmanship of Tamil Nadu — and she recognised that these treasures deserved to reach devotees worldwide.
        </p>
        <p style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.85;margin-bottom:1.25rem;">
          Every product we offer — from sacred brass idols to handcrafted Ayurvedic soaps — is personally selected and curated to bring authentic, time-honoured essentials into your home. We source directly from master craftsmen and traditional healers who have practised their trade for generations.
        </p>
        <p style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.85;">
          Rooted in Tamil Nadu's rich cultural heritage, Viha is more than a store. It is a living bridge between the wisdom of our ancestors and the needs of contemporary devotees worldwide.
        </p>
        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);">
          <p style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:var(--color-maroon);font-style:italic;">"Authenticity is not a feature. It is the foundation."</p>
          <p style="font-size:11px;color:rgba(45,45,45,0.5);margin-top:6px;text-transform:uppercase;letter-spacing:0.12em;">— Anitha Kuppusamy</p>
        </div>
      </div>
    </div>
  </div>
</section>

{%- comment -%} ── Our Values ────────────────────────────────────────────────── {%- endcomment -%}
<section style="background:var(--color-cream);padding:5rem 1.5rem;">
  <div style="max-width:1100px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">What We Stand For</p>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);margin-bottom:3rem;">Our Core Values</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:2rem;">
      {%- assign values = "Authentic Sourcing|Direct from master craftsmen and traditional healers across India — never mass-produced, never compromised.|🏺,Sacred Craftsmanship|Every item is hand-selected for energy, intention, and quality by Mrs Anitha Kuppusamy personally.|✦,Heritage Preservation|We document and preserve endangered craft traditions by ensuring artisans receive fair trade prices.|🌿,Holistic Wellness|Rooted in Ayurveda and Siddha medicine — products that nourish body, mind, and spirit together.|❤" | split: "," -%}
      {%- assign value_list = "Authentic Sourcing|Direct from master craftsmen and traditional healers across India — never mass-produced, never compromised.|Sacred Craftsmanship|Every item is hand-selected for energy, intention, and quality by Mrs Anitha Kuppusamy personally.|Heritage Preservation|We document and preserve endangered craft traditions by ensuring artisans receive fair trade prices.|Holistic Wellness|Rooted in Ayurveda and Siddha medicine — products that nourish body, mind, and spirit together." | split: "|" -%}
      {%- for i in (0..3) -%}
        {%- assign vi = i | times: 2 -%}
        {%- assign vd = vi | plus: 1 -%}
        <div style="background:var(--color-paper);padding:2rem;border-radius:2px;border:1px solid var(--color-cream-dark);text-align:left;">
          <div style="width:40px;height:40px;background:var(--color-maroon);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#fff" stroke-width="1.5" aria-hidden="true">
              {%- if i == 0 -%}<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>{%- endif -%}
              {%- if i == 1 -%}<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>{%- endif -%}
              {%- if i == 2 -%}<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>{%- endif -%}
              {%- if i == 3 -%}<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>{%- endif -%}
            </svg>
          </div>
          <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:900;color:var(--color-maroon);margin-bottom:0.625rem;">{{ value_list[vi] }}</h3>
          <p style="font-size:13px;color:rgba(45,45,45,0.7);line-height:1.75;">{{ value_list[vd] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} ── Heritage Timeline ─────────────────────────────────────────── {%- endcomment -%}
<section style="background:var(--color-paper);padding:5rem 1.5rem;">
  <div style="max-width:700px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Our Journey</p>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.75rem,4vw,2.5rem);font-weight:900;color:var(--color-maroon);margin-bottom:3rem;">Milestones of Devotion</h2>
    <div style="position:relative;padding-left:2rem;border-left:2px solid var(--color-cream-dark);text-align:left;">
      {%- assign milestones = "2010|Founded in Chennai, Tamil Nadu — Mrs. Anitha Kuppusamy begins curating sacred essentials from traditional artisans.|2015|Expanded to international shipping — serving the Indian diaspora across USA, UK, Canada and UAE.|2020|Crossed 50,000+ happy customers — trust built through authentic products and devotion to quality.|2023|Ships to 6 countries — delivering sacred traditions to devotees worldwide, every single day." | split: "|" -%}
      {%- for i in (0..3) -%}
        {%- assign yi = i | times: 2 -%}
        {%- assign di = yi | plus: 1 -%}
        <div style="position:relative;margin-bottom:2.5rem;padding-left:1.5rem;">
          <div style="position:absolute;left:-2.5rem;top:4px;width:16px;height:16px;border-radius:50%;background:var(--color-maroon);border:3px solid var(--color-paper);box-shadow:0 0 0 2px var(--color-gold);"></div>
          <p style="font-size:10px;font-weight:700;letter-spacing:0.16em;color:var(--color-gold);text-transform:uppercase;margin-bottom:0.375rem;">{{ milestones[yi] }}</p>
          <p style="font-size:14px;color:rgba(45,45,45,0.75);line-height:1.75;">{{ milestones[di] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- comment -%} ── CTA ──────────────────────────────────────────────────────── {%- endcomment -%}
<section style="background:var(--color-cream);padding:4rem 1.5rem;text-align:center;">
  <h2 style="font-family:var(--font-heading);font-size:clamp(1.5rem,4vw,2rem);font-weight:900;color:var(--color-maroon);margin-bottom:0.75rem;">Begin Your Sacred Journey</h2>
  <p style="font-size:14px;color:rgba(45,45,45,0.65);margin-bottom:2rem;max-width:420px;margin-left:auto;margin-right:auto;line-height:1.7;">Explore our carefully curated collection of authentic spiritual essentials, Ayurvedic wellness products and handcrafted jewellery.</p>
  <a href="/collections/all" class="btn btn--primary" style="display:inline-flex;align-items:center;gap:8px;">
    Shop All Essentials
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
  </a>
</section>

<style>
@media (max-width: 767px) {
  .story-two-col { grid-template-columns: 1fr !important; }
}
</style>

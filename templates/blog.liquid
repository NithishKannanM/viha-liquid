{%- comment -%}
  Blog listing template — viha-theme
  Handles all blogs (beauty journal, general, etc.)
  Assign via: /blogs/[blog-handle]
{%- endcomment -%}

<div style="background:var(--color-cream);">

  {%- comment -%} ── Hero ─── {%- endcomment -%}
  <section style="position:relative;width:100%;background:var(--color-maroon-dark);padding:5rem 3rem 4rem;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:0.04;background-image:radial-gradient(circle,#B8893D 1px,transparent 1px);background-size:20px 20px;pointer-events:none;"></div>
    <div style="max-width:var(--max-w);margin:0 auto;position:relative;z-index:1;">
      <nav aria-label="Breadcrumb" style="display:flex;align-items:center;gap:6px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:rgba(255,255,255,0.40);margin-bottom:1.5rem;">
        <a href="/" style="color:inherit;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='rgba(255,255,255,0.40)'">Home</a>
        <span>/</span>
        <span style="color:var(--color-gold);">{{ blog.title }}</span>
      </nav>
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.22em;color:var(--color-gold);margin-bottom:0.75rem;">Knowledge &amp; Ritual</span>
      <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.5rem);font-weight:900;color:#fff;line-height:1.05;margin-bottom:1rem;">
        {{ blog.title }}
      </h1>
      <p style="font-size:14px;color:rgba(255,255,255,0.60);max-width:480px;line-height:1.75;">
        Ayurvedic wisdom, ingredient stories, and ancestral beauty rituals — curated by Mrs Anitha Kuppusamy.
      </p>
    </div>
  </section>

  {%- comment -%} ── Article grid ─── {%- endcomment -%}
  {% paginate blog.articles by 9 %}
  <section style="padding:4rem 3rem;">
    <div style="max-width:var(--max-w);margin:0 auto;">

      {%- if blog.articles_count > 0 -%}

        {%- comment -%} Featured first article {%- endcomment -%}
        {%- assign first_article = blog.articles | first -%}
        <article style="display:grid;grid-template-columns:1fr;gap:0;border:1px solid var(--color-cream-dark);border-top:2px solid var(--color-gold);border-radius:2px;overflow:hidden;background:var(--color-paper);margin-bottom:2.5rem;transition:box-shadow 0.2s;"
          onmouseover="this.style.boxShadow='0 6px 24px rgba(0,0,0,0.10)'" onmouseout="this.style.boxShadow=''">
          <div style="display:grid;grid-template-columns:1fr;gap:0;">
            {%- if first_article.image -%}
              <a href="{{ first_article.url }}" style="display:block;aspect-ratio:16/7;overflow:hidden;" aria-hidden="true">
                <img
                  src="{{ first_article.image | img_url: '1200x' }}"
                  alt="{{ first_article.image.alt | default: first_article.title | escape }}"
                  loading="eager"
                  fetchpriority="high"
                  style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;"
                  onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform=''">
              </a>
            {%- endif -%}
            <div style="padding:2rem 2.5rem;">
              <div style="display:flex;align-items:center;gap:12px;margin-bottom:1rem;">
                {%- for tag in first_article.tags limit: 1 -%}
                  <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);background:rgba(184,137,61,0.10);border:1px solid rgba(184,137,61,0.25);padding:3px 9px;border-radius:2px;">{{ tag }}</span>
                {%- endfor -%}
                <span style="font-size:11px;color:rgba(45,45,45,0.45);display:flex;align-items:center;gap:4px;">
                  <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  {{ first_article.published_at | time_tag: '%b %e, %Y' }}
                </span>
              </div>
              <h2 style="font-family:var(--font-heading);font-size:clamp(1.3rem,3vw,1.875rem);font-weight:900;color:var(--color-maroon);margin-bottom:0.75rem;line-height:1.2;">
                <a href="{{ first_article.url }}" style="color:inherit;">{{ first_article.title }}</a>
              </h2>
              {%- if first_article.excerpt -%}
                <p style="font-size:14px;color:rgba(45,45,45,0.65);line-height:1.75;margin-bottom:1.5rem;max-width:620px;">{{ first_article.excerpt | strip_html | truncate: 200 }}</p>
              {%- endif -%}
              <a href="{{ first_article.url }}" class="btn btn--primary" style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:11px;">
                Read Article
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </div>
        </article>

        {%- comment -%} Remaining articles grid {%- endcomment -%}
        {%- if blog.articles_count > 1 -%}
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
            {%- for article in blog.articles offset: 1 -%}
              <article style="border:1px solid var(--color-cream-dark);border-top:2px solid transparent;border-radius:2px;overflow:hidden;background:var(--color-paper);display:flex;flex-direction:column;transition:box-shadow 0.2s,border-top-color 0.2s;"
                onmouseover="this.style.boxShadow='0 4px 18px rgba(0,0,0,0.09)';this.style.borderTopColor='var(--color-gold)'"
                onmouseout="this.style.boxShadow='';this.style.borderTopColor='transparent'">
                {%- if article.image -%}
                  <a href="{{ article.url }}" style="display:block;aspect-ratio:16/9;overflow:hidden;" aria-hidden="true">
                    <img
                      src="{{ article.image | img_url: '600x' }}"
                      alt="{{ article.image.alt | default: article.title | escape }}"
                      loading="lazy"
                      style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;"
                      onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''">
                  </a>
                {%- else -%}
                  <div style="aspect-ratio:16/9;background:var(--color-cream-dark);display:flex;align-items:center;justify-content:center;">
                    <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="color:rgba(45,45,45,0.20);" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                    </svg>
                  </div>
                {%- endif -%}

                <div style="padding:1.5rem;flex:1;display:flex;flex-direction:column;gap:0.75rem;">
                  <div style="display:flex;align-items:center;justify-content:space-between;">
                    {%- for tag in article.tags limit: 1 -%}
                      <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);">{{ tag }}</span>
                    {%- else -%}
                      <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);">Ayurveda</span>
                    {%- endfor -%}
                    <span style="font-size:10px;color:rgba(45,45,45,0.40);">{{ article.published_at | time_tag: '%b %Y' }}</span>
                  </div>

                  <h3 style="font-family:var(--font-heading);font-size:1.05rem;font-weight:700;color:var(--color-maroon);line-height:1.3;flex:1;">
                    <a href="{{ article.url }}" style="color:inherit;">{{ article.title }}</a>
                  </h3>

                  {%- if article.excerpt -%}
                    <p style="font-size:12px;color:rgba(45,45,45,0.65);line-height:1.65;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ article.excerpt | strip_html }}</p>
                  {%- endif -%}

                  <a href="{{ article.url }}" style="margin-top:auto;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:5px;padding-top:0.75rem;border-top:1px solid var(--color-cream-dark);transition:gap 0.15s;" onmouseover="this.style.gap='9px'" onmouseout="this.style.gap='5px'">
                    Read Article
                    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                  </a>
                </div>
              </article>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Pagination {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <div style="display:flex;justify-content:center;align-items:center;gap:8px;margin-top:3rem;flex-wrap:wrap;">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="btn btn--ghost" style="padding:10px 22px;font-size:11px;">← Newer</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="btn btn--ghost" style="padding:10px 16px;font-size:11px;">{{ part.title }}</a>
              {%- else -%}
                <span class="btn btn--primary" style="padding:10px 16px;font-size:11px;">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="btn btn--ghost" style="padding:10px 22px;font-size:11px;">Older →</a>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- else -%}
        <div style="text-align:center;padding:5rem 2rem;">
          <p style="font-size:14px;color:var(--color-muted);margin-bottom:1.5rem;">No articles published yet. Check back soon.</p>
          <a href="/" class="btn btn--ghost" style="padding:12px 24px;font-size:11px;">Return Home</a>
        </div>
      {%- endif -%}

    </div>
  </section>
  {% endpaginate %}

  {%- comment -%} ── Newsletter strip ─── {%- endcomment -%}
  <section style="padding:4rem 3rem;background:var(--color-maroon-dark);text-align:center;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;opacity:0.05;background-image:radial-gradient(circle,#B8893D 1px,transparent 1px);background-size:16px 16px;pointer-events:none;"></div>
    <div style="max-width:420px;margin:0 auto;position:relative;z-index:1;">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color:var(--color-gold);margin:0 auto 1rem;display:block;" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
      </svg>
      <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:900;color:#fff;margin-bottom:0.75rem;">The Beauty Digest</h2>
      <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:1.75rem;line-height:1.75;">Seasonal rituals, Ayurvedic wisdom, and early access to new formulations — delivered twice a month.</p>
      {% form 'customer', id: 'blog-newsletter' %}
        <div style="display:flex;gap:8px;">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label for="blog-email" class="sr-only">Email address</label>
          <input type="email" name="contact[email]" id="blog-email" required placeholder="your@email.com" aria-label="Email address"
            style="flex:1;padding:13px 16px;border:1px solid rgba(255,255,255,0.20);background:rgba(255,255,255,0.07);color:#fff;font-size:13px;border-radius:2px;font-family:inherit;outline:none;" onfocus="this.style.borderColor='var(--color-gold)'" onblur="this.style.borderColor='rgba(255,255,255,0.20)'">
          <button type="submit" class="btn btn--gold" style="padding:13px 18px;white-space:nowrap;font-size:11px;">Subscribe</button>
        </div>
        <p style="font-size:10px;color:rgba(255,255,255,0.30);margin-top:10px;">No spam. Unsubscribe anytime.</p>
      {% endform %}
    </div>
  </section>

</div>

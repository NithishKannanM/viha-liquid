<style>
.concern-card-wrap { grid-template-columns: repeat(2,1fr); }
@media (min-width:640px) {
  .concern-card-wrap { grid-template-columns: repeat(4,1fr); }
}
@media (min-width:1024px) {
  .concern-card-wrap { grid-template-columns: repeat(8,1fr); }
}
.concern-card:hover .concern-icon { background: var(--color-maroon); color: #fff; }
</style>

{%- comment -%} ── 3. FEATURED COLLECTIONS ─────────────────────────────────── {%- endcomment -%}
<section style="padding:4rem 3rem;background:var(--color-section-alt);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">Curated For You</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">Our Collections</h2>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">

      {%- assign collections_data = "Handmade Soaps;Cold-process herbal soaps with sacred botanicals for a gentle ritual cleanse.;handmade-soaps|Ayurvedic Oils;Time-extracted blends from seeds flowers and roots for face scalp and body.;ayurvedic-oils|Natural Perfumes;Alcohol-free attars and roll-ons distilled from pure floral and resinous sources.;natural-perfumes" | split: "|" -%}
      {%- for item in collections_data -%}
        {%- assign parts = item | split: ";" -%}
        {%- assign feat_col = collections[parts[2]] -%}
        <a href="/collections/{{ parts[2] }}"
          style="display:block;border:1px solid var(--color-cream-dark);border-top:2px solid transparent;border-radius:2px;overflow:hidden;background:var(--color-paper);transition:box-shadow 0.2s,border-top-color 0.2s;text-decoration:none;"
          onmouseover="this.style.boxShadow='0 6px 20px rgba(0,0,0,0.10)';this.style.borderTopColor='var(--color-gold)'"
          onmouseout="this.style.boxShadow='';this.style.borderTopColor='transparent'">
          <div style="aspect-ratio:3/2;overflow:hidden;position:relative;background:var(--color-cream);">
            {%- if feat_col.image -%}
              <img src="{{ feat_col.image | img_url: '800x' }}" alt="{{ parts[0] }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;filter:brightness(0.9);" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''">
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(15,90,67,0.20);">
                <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/></svg>
              </div>
            {%- endif -%}
            <span style="position:absolute;top:12px;left:12px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);background:rgba(253,249,241,0.92);padding:3px 9px;border-radius:2px;">{{ feat_col.products_count | default: 0 }} product{{ feat_col.products_count | pluralize: "", "s" }}</span>
          </div>
          <div style="padding:1.25rem;">
            <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:700;color:var(--color-maroon);margin-bottom:0.5rem;">{{ parts[0] }}</h3>

{%- comment -%}
  Generic page content — default template for any Shopify Page without a
  custom template (policy pages, future client-created pages).
  Renders the page title + rich-text body from Admin → Pages.
{%- endcomment -%}

<section class="page-content">
  <div class="page-content__inner">
    <header class="page-content__header">
      <h1 class="page-content__title">{{ page.title }}</h1>
      <span class="page-content__rule" aria-hidden="true"></span>
    </header>
    <div class="page-content__body rte">
      {{ page.content }}
    </div>
  </div>
</section>

<style>
.page-content { background: var(--color-cream, #FDF9F1); padding: 3.5rem 1.5rem 5rem; }
.page-content__inner { max-width: 820px; margin: 0 auto; }
.page-content__header { text-align: center; margin-bottom: 2.5rem; }
.page-content__title { font-family: var(--font-heading); font-size: clamp(26px, 4vw, 38px); color: var(--color-maroon); margin: 0 0 1rem; }
.page-content__rule { display: inline-block; width: 64px; height: 2px; background: var(--color-gold); }
.page-content__body { font-size: 15px; line-height: 1.85; color: var(--color-charcoal); }
.page-content__body h2, .page-content__body h3 { font-family: var(--font-heading); color: var(--color-maroon); margin: 2rem 0 0.75rem; }
.page-content__body p { margin: 0 0 1rem; }
.page-content__body a { color: var(--color-maroon); text-decoration: underline; }
.page-content__body ul, .page-content__body ol { padding-left: 1.5rem; margin: 0 0 1rem; }
.page-content__body img { max-width: 100%; height: auto; }
.page-content__body table { width: 100%; border-collapse: collapse; margin: 0 0 1rem; display: block; overflow-x: auto; }
.page-content__body td, .page-content__body th { border: 1px solid var(--color-cream-dark, #E5DED1); padding: 8px 12px; text-align: left; }
@media (max-width: 767px) { .page-content { padding: 2.5rem 1.25rem 3.5rem; } }
</style>

{% schema %}
{
  "name": "Page content",
  "settings": [],
  "presets": [{ "name": "Page content" }]
}
{% endschema %}

              <img src="{{ ing_col.image | img_url: '600x' }}" alt="{{ parts[0] }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;filter:brightness(0.9);transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''">
            {%- else -%}
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:rgba(15,90,67,0.20);">

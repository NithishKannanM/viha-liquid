{%- comment -%}
  Beauty page testimonials — renders the REAL Judge.me store-wide Reviews Carousel.
  Which reviews appear (e.g. positive + detailed only) is controlled in the Judge.me
  dashboard: Settings > Widgets > Reviews Carousel > Review curation.
  The carousel hydrates only on the published storefront (not in the Theme Editor
  design-mode preview, and not on localhost `shopify theme dev`) — a helper note is
  shown in design mode so the section isn't mistaken for empty.
  If a Judge.me "Reviews Carousel" app block is added via the editor it takes over.
{%- endcomment -%}
<section style="padding:4rem 3rem;background:var(--color-section-alt);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="text-align:center;margin-bottom:2.5rem;">
      <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">{{ section.settings.eyebrow | default: 'Real Results' }}</span>
      <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
      <div class="section__ornament" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:1rem;">
        <div class="section__ornament-line section__ornament-line--left"></div>
        <div class="section__ornament-diamond"></div>
        <div class="section__ornament-line section__ornament-line--right"></div>
      </div>
    </div>

    {%- assign app_blocks = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == '@app' -%}{%- assign app_blocks = app_blocks | plus: 1 -%}{%- endif -%}{%- endfor -%}

    {%- if app_blocks > 0 -%}
      {%- comment -%} A Judge.me app block was added via the editor — render it. {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == '@app' -%}{% render block %}{%- endif -%}
      {%- endfor -%}
    {%- elsif request.design_mode -%}
      {%- comment -%} Editor design-mode: Judge.me does not populate widgets here. {%- endcomment -%}
      <div style="border:1px dashed var(--color-cream-dark);border-radius:2px;background:var(--color-paper);padding:2.5rem 1.5rem;text-align:center;color:rgba(45,45,45,0.65);">
        <div style="font-family:var(--font-heading);font-weight:700;font-size:1rem;color:var(--color-maroon);margin-bottom:0.5rem;">Judge.me Reviews Carousel</div>
        <p style="font-size:13px;line-height:1.7;max-width:520px;margin:0 auto;">Live customer reviews appear here on the published store. Judge.me does not render in this editor preview — use the storefront <strong>Preview</strong> link to see the real reviews.<br><br>Choose which reviews show in <strong>Judge.me → Settings → Widgets → Reviews Carousel → Review curation</strong>.</p>
      </div>
    {%- else -%}
      {%- comment -%} Storefront: Judge.me's store-wide carousel. Populated by the app JS. {%- endcomment -%}
      <!-- Start of Judge.me code -->
      <div style='width:100%;'>
        <div class='jdgm-carousel-wrapper'>
          <div class='jdgm-carousel'></div>
        </div>
      </div>
      <!-- End of Judge.me code -->
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Beauty Reviews",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Real Results" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "paragraph", "content": "Shows your real Judge.me reviews carousel. Pick which reviews appear (e.g. 5-star only, or hand-picked detailed reviews) in Judge.me → Settings → Widgets → Reviews Carousel → Review curation. Reviews only appear on the published storefront, not in this editor preview." }
  ],
  "blocks": [
    { "type": "@app" }
  ],
  "presets": [
    { "name": "Beauty Reviews" }
  ]
}
{% endschema %}

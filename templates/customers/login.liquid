{% layout 'theme' %}

<div class="auth-page">
  <div class="auth-card">
    <div style="text-align:center;margin-bottom:2rem;">
      {% if settings.logo != blank %}
        <img src="{{ settings.logo | img_url: 'small' }}" alt="{{ shop.name }}" height="55" style="height:55px;margin:0 auto 1rem;">
      {% endif %}
      <h1 style="font-family:var(--font-heading);font-size:1.4rem;font-weight:900;color:var(--color-maroon);">Sign In</h1>
      <p style="font-size:12px;color:rgba(45,45,45,0.5);margin-top:4px;">Welcome back to your heritage account</p>
    </div>

    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <div>
        <label for="email" class="sr-only">Email</label>
        <input type="email" id="email" name="customer[email]" class="auth-input" placeholder="Email address" autocomplete="email" required>
      </div>
      <div>
        <label for="password" class="sr-only">Password</label>
        <input type="password" id="password" name="customer[password]" class="auth-input" placeholder="Password" autocomplete="current-password" required>
      </div>
      <div style="display:flex;justify-content:flex-end;margin-bottom:1rem;">
        <a href="/account/login#recover" style="font-size:11px;color:var(--color-gold);text-decoration:underline;">Forgot password?</a>
      </div>
      <button type="submit" class="btn btn--primary" style="width:100%;min-height:50px;">Sign In</button>
    {% endform %}

    <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--color-cream-dark);">
      <p style="font-size:12px;color:rgba(45,45,45,0.6);">New to Viha Heritage?</p>
      <a href="/account/register" class="btn btn--ghost" style="margin-top:0.75rem;display:block;width:100%;min-height:44px;">Create Account</a>
    </div>
  </div>
</div>

{%- comment -%} ── 8. BEAUTY JOURNAL ──────────────────────────────────────────── {%- endcomment -%}
<section id="beauty-journal" style="padding:4rem 3rem;background:var(--color-cream);border-top:1px solid var(--color-cream-dark);">
  <div style="max-width:var(--max-w);margin:0 auto;">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;">
      <div>
        <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">Education &amp; Ritual</span>
        <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,2rem);font-weight:900;color:var(--color-maroon);">Beauty Journal</h2>
      </div>
      <a href="/blogs/beauty" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.14em;color:var(--color-maroon);transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-maroon)'">
        All Articles
        <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>

    {%- comment -%}
      Check if the beauty blog has articles; fall back to hardcoded static cards if not.
    {%- endcomment -%}
    {%- assign beauty_blog = blogs['beauty'] -%}

    {%- if beauty_blog != blank and beauty_blog.articles_count > 0 -%}
      {%- comment -%} Live blog articles {%- endcomment -%}
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem;">
        {%- for article in beauty_blog.articles limit: 3 -%}
          <article style="border:1px solid var(--color-cream-dark);border-top:2px solid transparent;border-radius:2px;overflow:hidden;background:var(--color-paper);transition:box-shadow 0.2s,border-top-color 0.2s;" onmouseover="this.style.boxShadow='0 6px 20px rgba(0,0,0,0.09)';this.style.borderTopColor='var(--color-gold)'" onmouseout="this.style.boxShadow='';this.style.borderTopColor='transparent'">
            {%- if article.image -%}
              <a href="{{ article.url }}" style="display:block;aspect-ratio:3/2;overflow:hidden;" aria-hidden="true">
                <img src="{{ article.image | img_url: '600x' }}" alt="{{ article.image.alt | default: article.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''">
              </a>
            {%- endif -%}
            <div style="padding:1.5rem;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
                {%- for tag in article.tags limit: 1 -%}
                  <span style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-gold);background:rgba(184,137,61,0.10);border:1px solid rgba(184,137,61,0.20);padding:2px 7px;border-radius:2px;">{{ tag }}</span>
                {%- endfor -%}
              </div>
              <h3 style="font-family:var(--font-heading);font-size:1rem;font-weight:700;color:var(--color-maroon);margin-bottom:0.5rem;line-height:1.3;"><a href="{{ article.url }}" style="color:inherit;">{{ article.title }}</a></h3>
              {%- if article.excerpt -%}
                <p style="font-size:12px;color:rgba(45,45,45,0.65);line-height:1.65;margin-bottom:1rem;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{{ article.excerpt | strip_html }}</p>
              {%- endif -%}
              <a href="{{ article.url }}" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:5px;transition:gap 0.15s;" onmouseover="this.style.gap='9px'" onmouseout="this.style.gap='5px'">
                Read Article <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

    {%- else -%}
      <p style="text-align:center;color:var(--color-muted);font-size:13px;padding:2rem 0;">Our Beauty Journal is launching soon — check back for Ayurvedic rituals and skincare wisdom from Mrs Anitha Kuppusamy.</p>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ── 9. NEWSLETTER ─────────────────────────────────────────────── {%- endcomment -%}
<section style="padding:5rem 3rem;background:var(--color-maroon-dark);text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;opacity:0.07;background-image:radial-gradient(circle,#B8893D 1px,transparent 1px);background-size:16px 16px;pointer-events:none;"></div>
  <div style="max-width:480px;margin:0 auto;position:relative;z-index:1;">
    <svg width="30" height="30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="color:var(--color-gold);margin:0 auto 1.25rem;display:block;" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
    </svg>
    <span style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.2em;color:var(--color-gold);margin-bottom:0.75rem;">Beauty Newsletter</span>
    <h2 style="font-family:var(--font-heading);font-size:clamp(1.25rem,3vw,1.875rem);font-weight:900;color:#fff;margin-bottom:1rem;">The Beauty Digest</h2>
    <p style="font-size:13px;color:rgba(255,255,255,0.55);margin-bottom:2rem;line-height:1.75;">Seasonal rituals and Ayurvedic wisdom from Mrs Anitha Kuppusamy — plus early access to new formulations.</p>
    {% form 'customer', id: 'beauty-newsletter' %}
      <div style="display:flex;gap:8px;max-width:400px;margin:0 auto;">
        <input type="hidden" name="contact[tags]" value="newsletter,beauty">
        <label for="beauty-email" class="sr-only">Email address</label>
        <input type="email" name="contact[email]" id="beauty-email" required placeholder="your@email.com" aria-label="Email address"
          style="flex:1;padding:14px 16px;border:1px solid rgba(255,255,255,0.20);background:rgba(255,255,255,0.07);color:#fff;font-size:13px;border-radius:2px;font-family:inherit;outline:none;transition:border-color 0.2s;" onfocus="this.style.borderColor='var(--color-gold)'" onblur="this.style.borderColor='rgba(255,255,255,0.20)'">
        <button type="submit" class="btn btn--gold" style="padding:14px 20px;white-space:nowrap;font-size:11px;">Subscribe</button>
      </div>
      <p style="font-size:10px;color:rgba(255,255,255,0.30);margin-top:12px;font-style:italic;">No spam. Unsubscribe anytime.</p>
    {% endform %}
  </div>
</section>

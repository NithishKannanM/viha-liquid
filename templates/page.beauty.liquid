        <div class="concern-icon" style="width:44px;height:44px;border-radius:50%;background:rgba(15,90,67,0.08);display:flex;align-items:center;justify-content:center;color:var(--color-maroon);transition:all 0.2s;">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3.75c.966 0 1.75.784 1.75 1.75v1c0 .966-.784 1.75-1.75 1.75S10.25 7.466 10.25 6.5v-1c0-.966.784-1.75 1.75-1.75z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 9.25C8.548 9.25 5.75 12.048 5.75 15.5c0 2.623 1.5 4.9 3.686 6.02.453.232.972.23 1.42-.003l1.144-.62 1.144.62c.448.233.967.235 1.42.003C16.75 20.4 18.25 18.123 18.25 15.5c0-3.452-2.798-6.25-6.25-6.25z"/></svg>

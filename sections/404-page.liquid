{%- comment -%}
  404 page — keeps lost shoppers inside the store: search + key links.
{%- endcomment -%}

<section class="notfound">
  <div class="notfound__inner">
    <p class="notfound__code" aria-hidden="true">404</p>
    <h1 class="notfound__title">{{ section.settings.heading }}</h1>
    <p class="notfound__text">{{ section.settings.subtext }}</p>

    <form action="{{ routes.search_url }}" method="get" role="search" class="notfound__search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" class="notfound__input" placeholder="Search our products…" aria-label="Search products">
      <button type="submit" class="btn btn--primary notfound__btn">Search</button>
    </form>

    <div class="notfound__links">
      <a href="{{ routes.root_url }}" class="btn btn--ghost">Back to Home</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost">Browse All Products</a>
    </div>
  </div>
</section>

<style>
.notfound { background: var(--color-cream, #FDF9F1); padding: 5rem 1.5rem 6rem; text-align: center; }
.notfound__inner { max-width: 560px; margin: 0 auto; }
.notfound__code { font-family: var(--font-heading); font-size: clamp(64px, 12vw, 110px); font-weight: 700; color: var(--color-gold); line-height: 1; margin: 0 0 0.5rem; opacity: 0.55; }
.notfound__title { font-family: var(--font-heading); font-size: clamp(22px, 4vw, 32px); color: var(--color-maroon); margin: 0 0 0.75rem; }
.notfound__text { font-size: 14px; line-height: 1.75; color: rgba(45,45,45,0.7); margin: 0 0 1.75rem; }
.notfound__search { display: flex; gap: 8px; max-width: 420px; margin: 0 auto 1.5rem; }
.notfound__input { flex: 1; min-width: 0; font-size: 16px; padding: 12px 14px; border: 1px solid var(--color-cream-dark, #E5DED1); border-radius: 2px; background: #fff; color: var(--color-charcoal); }
.notfound__input:focus { outline: 2px solid var(--color-maroon); outline-offset: 1px; }
.notfound__btn { width: auto; min-height: 46px; padding: 0 1.25rem; }
.notfound__links { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
.notfound__links .btn { width: auto; min-height: 44px; padding: 10px 1.25rem; font-size: 11px; }
</style>

{% schema %}
{
  "name": "404 page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "We couldn't find that page" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The link may be old or the product may have moved. Try a search, or start from one of the pages below." }
  ],
  "presets": [{ "name": "404 page" }]
}
{% endschema %}

            <p style="font-size:12px;color:rgba(45,45,45,0.65);line-height:1.65;margin-bottom:0.75rem;">{{ parts[2] }}</p>
            <a href="/collections/{{ parts[3] }}" style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-maroon);display:inline-flex;align-items:center;gap:3px;transition:color 0.15s;" onmouseover="this.style.color='var(--color-gold)'" onmouseout="this.style.color='var(--color-maroon)'">

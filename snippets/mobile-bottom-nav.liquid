{%- comment -%} Mobile Bottom Navigation — visible below lg breakpoint {%- endcomment -%}
<nav class="mobile-bottom-nav" aria-label="Mobile navigation" role="navigation">

  <a href="/" class="mobile-bottom-nav__item" data-view="home"
    {% if request.path == '/' %}aria-current="page"{% endif %}>
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
    </svg>
    <span>Home</span>
  </a>

  <a href="/collections/all" class="mobile-bottom-nav__item" data-view="shop"
    {% if request.path contains '/collections' %}aria-current="page"{% endif %}>
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z"/>
    </svg>
    <span>Shop</span>
  </a>

  <a href="{% if customer %}/account{% else %}/account/login{% endif %}" class="mobile-bottom-nav__item" data-view="account">
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
    </svg>
    <span>{% if customer %}Account{% else %}Sign In{% endif %}</span>
  </a>

  <a href="/pages/wishlist" class="mobile-bottom-nav__item" data-view="wishlist"
    {% if request.path contains '/pages/wishlist' %}aria-current="page"{% endif %}>
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
    </svg>
    <span>Saved</span>
  </a>

  {% if settings.cart_type == 'drawer' %}
    <button class="mobile-bottom-nav__item" data-view="cart" data-cart-open aria-label="Open cart ({{ cart.item_count }} items)">
  {% else %}
    <a href="/cart" class="mobile-bottom-nav__item" data-view="cart">
  {% endif %}
      <div style="position:relative;display:inline-flex;align-items:center;justify-content:center;">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007z"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span data-cart-badge style="position:absolute;top:-6px;right:-8px;background:var(--color-maroon);color:#fff;width:16px;height:16px;border-radius:50%;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;" aria-live="polite">{{ cart.item_count }}</span>
        {% else %}
          <span data-cart-badge style="position:absolute;top:-6px;right:-8px;background:var(--color-maroon);color:#fff;width:16px;height:16px;border-radius:50%;font-size:9px;font-weight:700;display:none;align-items:center;justify-content:center;" aria-live="polite">0</span>
        {% endif %}
      </div>
      <span>Cart</span>
  {% if settings.cart_type == 'drawer' %}
    </button>
  {% else %}
    </a>
  {% endif %}

</nav>

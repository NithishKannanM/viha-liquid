{%- comment -%} FAQ page — assign template "page.faq" to a Page with handle "faq" in Shopify admin. {%- endcomment -%}

<section style="background:var(--color-paper);padding:3.5rem 1.5rem 2rem;">
  <div style="max-width:800px;margin:0 auto;text-align:center;">
    <p style="font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:var(--color-gold);margin-bottom:0.75rem;">Need Help?</p>
    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3rem);font-weight:900;color:var(--color-maroon);line-height:1.1;margin-bottom:0.75rem;">Frequently Asked Questions</h1>
    <p style="font-size:14px;color:rgba(45,45,45,0.65);line-height:1.75;">Answers to common questions about orders, shipping, returns, and our products. Can't find what you're looking for? <a href="/pages/contact" style="color:var(--color-maroon);text-decoration:underline;">Contact us</a>.</p>
  </div>
</section>

<div style="background:var(--color-paper);padding:1rem 1.5rem 5rem;">
  <div style="max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:2.5rem;">

    {%- assign faq_groups = "Orders & Shipping|How long does shipping take?~We ship across India within 5–7 business days and internationally within 10–15 business days, depending on destination customs processing.,Do you ship internationally?~Yes — we currently ship to 6 countries including the US, UK, Canada, Australia, Singapore, and the UAE. Shipping is free on orders over ₹999 (or the equivalent in your local currency).,How can I track my order?~Once your order ships, you'll receive a tracking link by email. You can also check status anytime on our Track Order page using your order ID.~~Returns & Refunds|What is your return policy?~We accept returns within 7 days of delivery for unused, unopened items in original packaging. See our full Returns &amp; Refunds policy for details.,How do I request a refund?~Contact us with your order number and reason for return. Once we receive and inspect the item, refunds are processed within 5–7 business days to your original payment method.,Are sacred/pooja items returnable?~For hygiene and ritual-use reasons, opened consumables, idols that have been consecrated, and personal-use Ayurvedic items are not eligible for return unless defective.~~Products & Authenticity|Are your products genuinely handcrafted?~Yes. Every item is sourced directly from verified traditional artisans across Tamil Nadu and India, personally vetted by our founder Mrs Anitha Kuppusamy.,Are your Ayurvedic products certified?~Our Ayurvedic and herbal products use pure, traditionally-sourced ingredients. Certification details are listed on individual product pages where applicable.,Can I get help choosing the right product?~Absolutely — reach out via WhatsApp or our Contact page and our team will help you choose based on your ritual, gifting, or wellness needs." | split: "~~" -%}

    {%- for group in faq_groups -%}
      {%- assign group_parts = group | split: "|" -%}
      {%- assign group_title = group_parts[0] -%}
      {%- assign group_items = group_parts[1] | split: "," -%}
      <div>
        <h2 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:900;color:var(--color-maroon);padding-bottom:0.75rem;border-bottom:1px solid var(--color-cream-dark);margin-bottom:0.5rem;">{{ group_title }}</h2>
        {%- for item in group_items -%}
          {%- assign qa = item | split: "~" -%}
          <details style="border-bottom:1px solid var(--color-cream-dark);padding:1rem 0;">
            <summary style="cursor:pointer;list-style:none;font-size:14px;font-weight:700;color:var(--color-charcoal);display:flex;align-items:center;justify-content:space-between;gap:1rem;">
              {{ qa[0] }}
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;color:var(--color-gold);" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
            </summary>
            <p style="font-size:13px;color:rgba(45,45,45,0.68);line-height:1.75;margin-top:0.75rem;">{{ qa[1] }}</p>
          </details>
        {%- endfor -%}
      </div>
    {%- endfor -%}

  </div>
</div>

<style>
details > summary { outline: none; }
details > summary::-webkit-details-marker { display: none; }
details[open] summary svg { transform: rotate(180deg); }
details summary svg { transition: transform 0.2s; }
</style>

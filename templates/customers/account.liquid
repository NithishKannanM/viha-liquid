{% layout 'theme' %}

<div class="container" style="padding-top:3rem;padding-bottom:4rem;min-height:60vh;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:1rem;">
    <div>
      <h1 style="font-family:var(--font-heading);font-size:1.75rem;font-weight:900;color:var(--color-maroon);">My Account</h1>
      <p style="font-size:13px;color:rgba(45,45,45,0.6);margin-top:4px;">Welcome back, {{ customer.first_name }}</p>
    </div>
    <a href="/account/logout" style="font-size:11px;color:rgba(45,45,45,0.5);text-decoration:underline;">Sign Out</a>
  </div>

  <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="account-grid">
    <style>@media(min-width:768px){.account-grid{grid-template-columns:240px 1fr!important;}}</style>

    {%- comment -%} Sidebar {%- endcomment -%}
    <nav style="align-self:flex-start;" aria-label="Account navigation">
      {%- assign nav_items = "Orders,/account|Addresses,/account/addresses|Wishlist,/wishlist" | split: "|" -%}
      {%- for item in nav_items -%}
        {%- assign parts = item | split: "," -%}
        <a href="{{ parts[1] }}" style="display:flex;align-items:center;padding:0.875rem 1rem;font-size:13px;font-weight:500;color:rgba(45,45,45,0.8);border-radius:2px;margin-bottom:4px;transition:all 0.15s;text-decoration:none;"
          onmouseover="this.style.background='var(--color-cream-dark)';this.style.color='var(--color-maroon)'"
          onmouseout="this.style.background='';this.style.color='rgba(45,45,45,0.8)'">
          {{ parts[0] }}
        </a>
      {%- endfor -%}
    </nav>

    {%- comment -%} Order history {%- endcomment -%}
    <div>
      <h2 style="font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:var(--color-maroon);margin-bottom:1.25rem;">Order History</h2>
      {% if customer.orders.size > 0 %}
        {% for order in customer.orders %}
          <div style="background:var(--color-paper);border:1px solid var(--color-cream-dark);padding:1.25rem;margin-bottom:1rem;border-radius:2px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;margin-bottom:1rem;">
              <div>
                <a href="{{ order.customer_url }}" style="font-family:var(--font-heading);font-size:13px;font-weight:700;color:var(--color-maroon);text-decoration:none;">Order #{{ order.order_number }}</a>
                <p style="font-size:11px;color:rgba(45,45,45,0.5);margin-top:2px;">{{ order.created_at | date: '%B %d, %Y' }}</p>
              </div>
              <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;padding:4px 10px;border-radius:2px;
                background:{% case order.financial_status %}{% when 'paid' %}rgba(16,185,129,0.1){% when 'pending' %}rgba(245,158,11,0.1){% else %}rgba(45,45,45,0.08){% endcase %};
                color:{% case order.financial_status %}{% when 'paid' %}#059669{% when 'pending' %}#d97706{% else %}rgba(45,45,45,0.6){% endcase %};">
                {{ order.financial_status | capitalize }}
              </span>
            </div>
            <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;" class="scrollbar-hide">
              {% for line_item in order.line_items limit: 4 %}
                {% if line_item.image %}
                  <img src="{{ line_item.image | img_url: '80x80', crop: 'center' }}" alt="{{ line_item.title }}" loading="lazy" width="56" height="56" style="width:56px;height:56px;object-fit:contain;border:1px solid var(--color-cream-dark);border-radius:2px;flex-shrink:0;padding:2px;">
                {% endif %}
              {% endfor %}
            </div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid var(--color-cream-dark);">
              <span style="font-size:12px;color:rgba(45,45,45,0.6);">{{ order.line_items.size }} item{{ order.line_items.size | pluralize: '', 's' }} · {{ order.total_price | money }}</span>
              <a href="{{ order.customer_url }}" style="font-size:11px;font-weight:600;color:var(--color-maroon);text-decoration:underline;">View Details</a>
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div style="text-align:center;padding:3rem 0;color:rgba(45,45,45,0.5);">
          <p style="margin-bottom:1rem;">You haven't placed any orders yet.</p>
          <a href="/collections/all" class="btn btn--primary" style="display:inline-flex;width:auto;">Start Shopping</a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

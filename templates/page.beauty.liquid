      {%- for item in ingredients -%}
        {%- assign parts = item | split: ";" -%}
        {%- assign ing_col = collections[parts[3]] -%}
        <div style="border:1px solid var(--color-cream-dark);border-radius:2px;overflow:hidden;background:var(--color-cream);transition:box-shadow 0.2s,border-color 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.09)';this.style.borderColor='rgba(15,90,67,0.3)'" onmouseout="this.style.boxShadow='';this.style.borderColor='var(--color-cream-dark)'">
